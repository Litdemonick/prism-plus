{
  "name": "prism-plus",
  "version": "1.0.0",
  "description": "Universal open-source extension core for streaming media — anime, manga, movies, series, live TV, novels, and more",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Litdemonick/prism-plus"
  },
  "keywords": [
    "prismhub",
    "extensions",
    "anime",
    "manga",
    "movies",
    "streaming",
    "typescript",
    "open-source"
  ],
  "scripts": {
    "keygen": "node scripts/keygen.mjs",
    "validate": "node scripts/validate.mjs",
    "build": "npm run validate && node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
